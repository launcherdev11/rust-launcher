{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "16Launcher",
  "version": "2.1.0",
  "identifier": "com.16steyy.16Launcher",

  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "16Launcher",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*; img-src 'self' https: asset: http://asset.localhost data: blob:; media-src 'self' https: asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": ["$APPDATA/16Launcher/**", "$DATA/16Launcher/**"]
        }
      }
    }
  },

  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm", "nsis", "dmg"],
    "fileAssociations": [
      {
        "ext": ["mrpack"],
        "name": "Modrinth Modpack",
        "description": "Modrinth modpack (.mrpack)",
        "mimeType": "application/octet-stream"
      }
    ],
    "resources": [
      "resources/bootstrap.jar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator"
        ]
      }
    }
  },

  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwNzkxNTE1RDY5MzNFRDMKUldUVFBwUFdGUlY1b04yR0RvNG5FUDNpTW9nOWgzVEJsMGZiUnlPT1Y3TTNVa0NGSGp0bWUzclMK",
      "endpoints": [
        "https://github.com/launcherdev11/rust-launcher/releases/latest/download/beta.json"
      ]
    }
  }
}